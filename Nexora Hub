    local scanProperties = { Position = UDim2.new(0, 0, 1, -2) } 
    TweenService:Create(ScanLine, scanInfo, scanProperties):Play()
    
    -- Tab Switching Logic
    local function switchTab(selectedTabName)
        for name, button in pairs(tabButtons) do
            button.BackgroundColor3 = TAB_LIST_COLOR
            button.BackgroundTransparency = TRANSPARENCY_LEVEL 
            if button:FindFirstChildOfClass("UIStroke") then
                button:FindFirstChildOfClass("UIStroke"):Destroy() 
            end
        end
        for name, content in pairs(tabContents) do
            content.Visible = false
        end
        
        if tabContents[selectedTabName] then
            local content = tabContents[selectedTabName]
            content.Visible = true
            -- Set CanvasSize based on content height (assuming 2 columns here)
            local column1 = content:FindFirstChild("MiningColumn")
            local column2 = content:FindFirstChild("CombatColumn")
            
            local totalHeight = 0
            if column1 and column2 then
                totalHeight = math.max(column1.AbsoluteSize.Y, column2.AbsoluteSize.Y)
            elseif column1 then
                totalHeight = column1.AbsoluteSize.Y
            end
            
            ContentArea.CanvasSize = UDim2.new(0, 0, 0, totalHeight + CONTENT_PADDING * 2) 
        end
        if tabButtons[selectedTabName] then
            local button = tabButtons[selectedTabName]
            button.BackgroundColor3 = ACCENT_COLOR 
            button.BackgroundTransparency = TRANSPARENCY_LEVEL - 0.2 
            createStroke(button, GLOW_STROKE_COLOR, 0.3) 
        end
    end
    
    local function createTab(tabName, icon, isDefault)
        local button = Instance.new("TextButton")
        -- ... (โค้ด Button เหมือน V9.0) ...
        button.Name = tabName.."Tab"
        button.Size = UDim2.new(1, -5, 0, 30)
        button.Position = UDim2.new(0, 2, 0, 0)
        button.Text = icon.." "..tabName
        button.TextColor3 = TEXT_COLOR
        button.BackgroundColor3 = isDefault and ACCENT_COLOR or TAB_LIST_COLOR 
        button.BackgroundTransparency = isDefault and TRANSPARENCY_LEVEL - 0.2 or TRANSPARENCY_LEVEL 
        button.Font = Enum.Font.SourceSans
        button.TextSize = 16
        button.TextXAlignment = Enum.TextXAlignment.Left
        button.Parent = TabList
        
        local corner = Instance.new("UICorner")
        corner.CornerRadius = CORNER_RADIUS
        corner.Parent = button
        
        if isDefault then
            createStroke(button, GLOW_STROKE_COLOR, 0.3)
        end
        
        local content = Instance.new("Frame")
        content.Name = tabName.."Content"
        content.Size = UDim2.new(1, 0, 1, 0) -- Full size to fit ContentArea
        content.BackgroundColor3 = BACKGROUND_COLOR
        content.BackgroundTransparency = 1 
        content.Parent = ContentArea
        content.Visible = isDefault or false 
        
        button.MouseButton1Click:Connect(function()
            switchTab(tabName)
        end)
        
        tabButtons[tabName] = button
        tabContents[tabName] = content

        return content
    end

